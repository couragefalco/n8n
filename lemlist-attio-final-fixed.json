      "typeVersion": 1,
      "position": [140, 620]
    },
    {
      "parameters": {
        "resource": "lead",
        "operation": "get",
        "email": "={{ $json.email }}"
      },
      "id": "get-lead",
      "name": "Get Lead Details",
      "type": "n8n-nodes-base.lemlist",
      "typeVersion": 2,
      "position": [360, 440]
    },
    {
      "parameters": {
        "jsCode": "const leadData = $json;\nconst webhookData = $input.item.json;\n\n// Determine if interested\nconst isInterested = webhookData.type === 'interested' || \n                   webhookData.type === 'emailsInterested' || \n                   webhookData.type === 'linkedinInterested';\n\n// Set priority and deadline\nconst priority = isInterested ? 'high' : 'medium';\nconst deadlineHours = isInterested ? 4 : 24;\n\n// Create full name\nconst fullName = [leadData.firstName, leadData.lastName]\n  .filter(name => name && name.trim())\n  .join(' ') || leadData.email?.split('@')[0] || 'Unknown';\n\n// Task title\nconst actionText = isInterested ? 'INTERESTED LEAD' : 'Reply Received';\nlet taskTitle = `${actionText}: ${fullName}`;\nif (leadData.companyName) {\n  taskTitle += ` (${leadData.companyName})`;\n}\n\nreturn {\n  email: leadData.email || '',\n  firstName: leadData.firstName || '',\n  lastName: leadData.lastName || '',\n  fullName: fullName,\n  companyName: leadData.companyName || '',\n  jobTitle: leadData.title || leadData.jobTitle || '',\n  phone: leadData.phone || '',\n  linkedinUrl: leadData.linkedinUrl || '',\n  isInterested: isInterested,\n  priority: priority,\n  deadlineHours: deadlineHours,\n  taskTitle: taskTitle,\n  campaignId: leadData.campaignId || webhookData.campaignId || ''\n};"
      },
      "id": "process-data",
      "name": "Process Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [560, 440]
    },
    {
      "parameters": {
        "operation": "List Records",
        "object": "people",
        "filter[1][attribute]": "email_addresses",
        "filter[1][value]": "={{ $json.email }}"
      },
      "id": "search-person",
      "name": "Search Person",
      "type": "n8n-nodes-attio.attio",
      "typeVersion": 1,
      "position": [760, 440],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "leftValue": "={{ $json.data?.length || 0 }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ]
        }
      },
      "id": "person-exists",
      "name": "Person Exists?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [960, 440]
    },
    {
      "parameters": {
        "operation": "Update Record (Append)",
        "object": "people",
        "record_id": "={{ $json.data[0].id.record_id }}",
        "job_title": "={{ $('Process Data').item.json.jobTitle }}",
        "phone_numbers": "={{ $('Process Data').item.json.phone ? [{\"phone_number\": $('Process Data').item.json.phone}] : [] }}"
      },
      "id": "update-person",
      "name": "Update Person",
      "type": "n8n-nodes-attio.attio",
