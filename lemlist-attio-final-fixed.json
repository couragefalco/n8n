    },
    {
      "parameters": {
        "operation": "Create Task",
        "title": "={{ $json.leadData.taskTitle }}",
        "description": "Lead responded{{ $json.leadData.isInterested ? ' and is INTERESTED' : '' }}\\n\\nContact: {{ $json.leadData.email }}\\nCompany: {{ $json.leadData.companyName || 'Not specified' }}\\nJob Title: {{ $json.leadData.jobTitle || 'Not specified' }}\\n\\n{{ $json.leadData.isInterested ? '⚡ HIGH PRIORITY - Follow up immediately!' : 'Standard follow-up required.' }}",
        "deadline_at": "={{ new Date(Date.now() + $json.leadData.deadlineHours * 60 * 60 * 1000).toISOString() }}",
        "status": "pending",
        "assignees": "[{\"referenced_actor_type\": \"workspace_member\", \"referenced_actor_id\": \"66ca8855-38db-4976-a627-584e8799535b\"}]",
        "linked_records": "[{\"target_object\": \"people\", \"target_record_id\": \"{{ $json.personId }}\"}]"
      },
      "id": "create-task",
      "name": "Create Task",
      "type": "n8n-nodes-attio.attio",
      "typeVersion": 1,
      "position": [1560, 440]
